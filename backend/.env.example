# GuruPix Backend — copy to .env and adjust for local/dev
# See docs/DEVELOPER_GUIDE.md for setup.

# Database (must match infra/docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://gurupix:gurupix_local@localhost:5432/gurupix
# Sync URL for Alembic (use same host/user/password/db, sync driver)
# DATABASE_URL_SYNC=postgresql://gurupix:gurupix_local@localhost:5432/gurupix

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# App
ENV=development
DEBUG=true
LOG_LEVEL=INFO
# RATE_LIMIT_PER_MINUTE=500  # default in dev; use 100 in production

# Auth — JWT (Stage 4)
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Auth — Google OAuth (Stage 4)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Where Google redirects after sign-in. Must match exactly what you add in Google Cloud Console.
# For local dev (frontend on 5173): OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback
# If unset, uses OAUTH_CALLBACK_BASE_URL + /api/v1/auth/google/callback (backend receives redirect).
OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback
# OAUTH_CALLBACK_BASE_URL=http://localhost:8000  # fallback when OAUTH_REDIRECT_URI unset

# Admin (Stage 5) — comma-separated emails allowed to call /ingest/items
ADMIN_EMAILS=admin@gurupix.com

# Optional: MinIO (if using minio profile in docker-compose)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=gurupix-raw
